    "sentaku/contracts/redeemer/OracleAttestation": {
      "title": "OracleAttestation",
      "description": "Oracle-signed price attestation.\n\n Message format (deterministic, 17 bytes):\n   symbol_index (1 byte) ++ price (8 bytes big-endian) ++ observed_at (8 bytes big-endian)\n\n Validator verifies Ed25519 signature over this message and checks that\n blake2b_224(oracle_pubkey) matches the parameterized oracle pubkey hash.",
      "anyOf": [
        {
          "title": "OracleAttestation",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "price",
              "description": "The attested settlement price (micro-USD, PRICE_SCALE = 1_000_000)",
              "$ref": "#/definitions/sentaku~1contracts~1types~1Price"
            },
            {
              "title": "observed_at",
              "description": "POSIX time (ms) at which the price was observed",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "signature",
              "description": "Ed25519 signature (64 bytes) over the deterministic message",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "oracle_pubkey",
              "description": "Oracle's Ed25519 public key (32 bytes) — verified against parameterized hash",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    },
